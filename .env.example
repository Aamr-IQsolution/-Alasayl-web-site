# Email Configuration (Resend)
# With FROM_EMAIL=onboarding@resend.dev, Resend only delivers to the email
# address of your Resend account (sandbox). For other recipients, verify a
# domain at https://resend.com/domains and set FROM_EMAIL to an address on that domain.
RESEND_API_KEY=your_resend_api_key_here
COMPANY_EMAIL=alasayltransport@gmail.com
FROM_EMAIL=onboarding@resend.dev

# Optional - For Later
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_id
